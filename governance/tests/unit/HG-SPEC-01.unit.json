{
  "gate_id": "HG-SPEC-01",
  "description": "Unit test cases for the PII Declaration Gate. Tests every meaningful combination of compliance[], pii_fields[], and encryption field states.",
  "test_cases": [
    {
      "id": "HG-SPEC-01-U-001",
      "description": "Not triggered — no compliance declared, no pii_fields",
      "inputs": { "compliance": [], "pii_fields": [], "encryption": null },
      "expected": "PASS"
    },
    {
      "id": "HG-SPEC-01-U-002",
      "description": "FAIL — GDPR declared, pii_fields empty, no encryption",
      "inputs": { "compliance": ["GDPR"], "pii_fields": [], "encryption": null },
      "expected": "FAIL"
    },
    {
      "id": "HG-SPEC-01-U-003",
      "description": "FAIL — HIPAA declared, pii_fields empty, no encryption",
      "inputs": { "compliance": ["HIPAA"], "pii_fields": [], "encryption": null },
      "expected": "FAIL"
    },
    {
      "id": "HG-SPEC-01-U-004",
      "description": "FAIL — compliance declared, pii_fields populated, no encryption object",
      "inputs": { "compliance": ["GDPR"], "pii_fields": ["email"], "encryption": null },
      "expected": "FAIL"
    },
    {
      "id": "HG-SPEC-01-U-005",
      "description": "FAIL — pii_fields populated, encryption present but at_rest is missing",
      "inputs": {
        "compliance": ["GDPR"],
        "pii_fields": ["email", "full_name"],
        "encryption": { "at_rest": null, "in_transit": "TLS 1.3" }
      },
      "expected": "FAIL"
    },
    {
      "id": "HG-SPEC-01-U-006",
      "description": "FAIL — pii_fields populated, encryption present but in_transit is missing",
      "inputs": {
        "compliance": ["GDPR"],
        "pii_fields": ["email"],
        "encryption": { "at_rest": "AES-256", "in_transit": null }
      },
      "expected": "FAIL"
    },
    {
      "id": "HG-SPEC-01-U-007",
      "description": "FAIL — encryption.at_rest is vague: 'industry-standard measures'",
      "inputs": {
        "compliance": ["GDPR"],
        "pii_fields": ["email"],
        "encryption": { "at_rest": "industry-standard measures", "in_transit": "TLS 1.3" }
      },
      "expected": "FAIL"
    },
    {
      "id": "HG-SPEC-01-U-008",
      "description": "FAIL — encryption.at_rest is vague: 'appropriate security controls'",
      "inputs": {
        "compliance": ["GDPR"],
        "pii_fields": ["email"],
        "encryption": { "at_rest": "appropriate security controls", "in_transit": "TLS 1.3" }
      },
      "expected": "FAIL"
    },
    {
      "id": "HG-SPEC-01-U-009",
      "description": "FAIL — encryption.in_transit is vague: 'standard security protocols'",
      "inputs": {
        "compliance": ["GDPR"],
        "pii_fields": ["email"],
        "encryption": { "at_rest": "AES-256", "in_transit": "standard security protocols" }
      },
      "expected": "FAIL"
    },
    {
      "id": "HG-SPEC-01-U-010",
      "description": "FAIL — pii_fields populated with no compliance, no encryption",
      "inputs": { "compliance": [], "pii_fields": ["email"], "encryption": null },
      "expected": "FAIL"
    },
    {
      "id": "HG-SPEC-01-U-011",
      "description": "PASS — GDPR declared, pii_fields populated, specific encryption",
      "inputs": {
        "compliance": ["GDPR"],
        "pii_fields": ["email", "full_name"],
        "encryption": { "at_rest": "AES-256", "in_transit": "TLS 1.3" }
      },
      "expected": "PASS"
    },
    {
      "id": "HG-SPEC-01-U-012",
      "description": "PASS — HIPAA declared, pii_fields populated, specific encryption",
      "inputs": {
        "compliance": ["HIPAA"],
        "pii_fields": ["patient_name", "date_of_birth", "medical_notes"],
        "encryption": { "at_rest": "AES-256", "in_transit": "TLS 1.3" }
      },
      "expected": "PASS"
    },
    {
      "id": "HG-SPEC-01-U-013",
      "description": "PASS — multiple compliance declarations, pii_fields populated, specific encryption",
      "inputs": {
        "compliance": ["GDPR", "HIPAA"],
        "pii_fields": ["email", "name", "dob"],
        "encryption": { "at_rest": "AES-256", "in_transit": "TLS 1.3" }
      },
      "expected": "PASS"
    },
    {
      "id": "HG-SPEC-01-U-014",
      "description": "FAIL — encryption object is empty {}",
      "inputs": {
        "compliance": ["GDPR"],
        "pii_fields": ["email"],
        "encryption": {}
      },
      "expected": "FAIL"
    }
  ]
}
